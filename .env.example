# CMMS environment template
# Copy this file to .env for local development and replace all placeholder values.
# Do not commit real secrets.

APP_ENV=development

# Docker Compose service ports.
FRONTEND_PORT=5173
BACKEND_PORT=8000
POSTGRES_PORT=5432
MAILPIT_SMTP_PORT=1025
MAILPIT_WEB_PORT=8025

# PostgreSQL container configuration.
POSTGRES_DB=cmms_dev
POSTGRES_USER=cmms_user
POSTGRES_PASSWORD=replace-with-local-db-password
TZ=Africa/Cairo

# Local PostgreSQL development database.
# Use DATABASE_URL when running the backend directly on Windows.
DATABASE_URL=postgresql://cmms_user:replace-with-local-db-password@127.0.0.1:5432/cmms_dev

# Use DOCKER_DATABASE_URL when running the backend inside Docker Compose.
DOCKER_DATABASE_URL=postgresql://cmms_user:replace-with-local-db-password@postgres:5432/cmms_dev

# Required in production.
# Also recommended in development so a local admin account can be created automatically.
ADMIN_USERNAME=replace-with-admin-username
ADMIN_PASSWORD=replace-with-strong-admin-password
JWT_SECRET_KEY=replace-with-a-long-random-secret-at-least-32-characters

# Optional.
ADMIN_EMAIL=admin@example.com
FRONTEND_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
VITE_API_BASE=http://127.0.0.1:8000/api
CHOKIDAR_USEPOLLING=true
POSTGRES_WAIT_TIMEOUT_SECONDS=60
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Optional SMTP settings for inventory low-stock email alerts.
# Docker development uses Mailpit by default when SMTP_HOST is empty.
# Users receive these emails only when the admin grants Inventory / Email Alerts.
SMTP_HOST=
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=cmms-test@local.test
SMTP_USE_TLS=false

# SQLite fallback remains available for compatibility.
# To use SQLite locally, comment DATABASE_URL above.
